<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.DashboardController"
            prefWidth="900" prefHeight="600">

    <!-- ══ HAUT : barre de navigation ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1a2e; -fx-padding: 15px;">

            <Label text="💰 MoneyWise"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <!-- Espace flexible -->
            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelBienvenue"
                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>

            <Button text="Déconnexion"
                    onAction="#handleDeconnexion"
                    style="-fx-background-color: #e63946; -fx-text-fill: white;
                           -fx-background-radius: 6px;"/>
        </HBox>
    </top>

    <!-- ══ GAUCHE : menu latéral ══ -->
    <left>
        <VBox spacing="5"
              style="-fx-background-color: #16213e; -fx-padding: 20px;"
              prefWidth="180">

            <Label text="MENU"
                   style="-fx-text-fill: #666; -fx-font-size: 11px;"/>

            <Button text="📊 Dashboard"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4361ee; -fx-text-fill: white;
                           -fx-background-radius: 6px; -fx-padding: 10px;"/>

            <Button text="💸 Transactions"
                    maxWidth="Infinity"
                    onAction="#handleTransactions"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-background-radius: 6px; -fx-padding: 10px;"/>

            <Button text="🎯 Budgets"
                    maxWidth="Infinity"
                    onAction="#handleBudgets"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-background-radius: 6px; -fx-padding: 10px;"/>

            <Button text="📤 Export"
                    maxWidth="Infinity"
                    onAction="#handleExport"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-background-radius: 6px; -fx-padding: 10px;"/>

            <Button text="⚙️ Admin"
                    maxWidth="Infinity"
                    onAction="#handleAdmin"
                    style="-fx-background-color: #f4a261; -fx-text-fill: white;
               -fx-background-radius: 6px; -fx-padding: 10px;"/>
        </VBox>
    </left>

    <!-- ══ CENTRE : contenu principal ══ -->
    <center>
        <VBox spacing="20" style="-fx-padding: 25px; -fx-background-color: #f0f2f5;">

            <!-- Cartes résumé -->
            <HBox spacing="15">

                <!-- Carte Solde -->
                <VBox styleClass="carte-stat" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 20px;
                             -fx-background-radius: 10px;">
                    <Label text="💰 Solde actuel"
                           style="-fx-text-fill: #666; -fx-font-size: 13px;"/>
                    <Label fx:id="labelSolde" text="0.00 €"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #1a1a2e;"/>
                </VBox>

                <!-- Carte Revenus -->
                <VBox styleClass="carte-stat" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 20px;
                             -fx-background-radius: 10px;">
                    <Label text="📈 Revenus"
                           style="-fx-text-fill: #666; -fx-font-size: 13px;"/>
                    <Label fx:id="labelRevenus" text="0.00 €"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #2dc653;"/>
                </VBox>

                <!-- Carte Dépenses -->
                <VBox styleClass="carte-stat" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 20px;
                             -fx-background-radius: 10px;">
                    <Label text="📉 Dépenses"
                           style="-fx-text-fill: #666; -fx-font-size: 13px;"/>
                    <Label fx:id="labelDepenses" text="0.00 €"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                  -fx-text-fill: #e63946;"/>
                </VBox>


            </HBox>

            <!-- ══ Zone des alertes ══ -->
            <VBox fx:id="zoneAlertes" spacing="8" managed="false" visible="false"/>

            <!-- Graphiques -->
            <HBox spacing="15" VBox.vgrow="ALWAYS">

                <!-- BarChart : Revenus vs Dépenses -->
                <BarChart fx:id="barChart"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10px;">
                    <xAxis>
                        <CategoryAxis label="Mois"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Montant (€)"/>
                    </yAxis>
                </BarChart>

                <!-- PieChart : Dépenses par catégorie -->
                <PieChart fx:id="pieChart"
                          HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10px;"
                          title="Dépenses par catégorie"/>

            </HBox>

        </VBox>
    </center>

</BorderPane>