<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.DashboardController"
            prefWidth="900" prefHeight="600">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="navbar" prefHeight="60">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="MoneyWise" styleClass="navbar-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelBienvenue" styleClass="navbar-user"/>

            <Button text="Deconnexion"
                    styleClass="btn-danger"
                    onAction="#handleDeconnexion"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar">

            <Label text="NAVIGATION" styleClass="sidebar-section-title"/>

            <Button text="Dashboard"
                    styleClass="menu-btn, menu-btn-active"
                    maxWidth="Infinity"/>

            <Button text="Transactions"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#handleTransactions"/>

            <Button text="Budgets"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#handleBudgets"/>

            <Button text="Export"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#handleExport"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnAdmin"
                    text="Administration"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#handleAdmin"
                    visible="false" managed="false"/>

        </VBox>
    </left>

    <!-- CONTENU -->
    <center>
        <VBox fx:id="contentRoot" spacing="20" styleClass="content-area">

            <!-- Alertes -->
            <VBox fx:id="zoneAlertes" spacing="8"
                  managed="false" visible="false"/>

            <!-- Cartes -->
            <HBox spacing="16">

                <VBox styleClass="card, card-solde" HBox.hgrow="ALWAYS">
                    <Label text="Solde actuel" styleClass="card-titre"/>
                    <Region prefHeight="8"/>
                    <Label fx:id="labelSolde" text="0,00 €"
                           styleClass="card-valeur, valeur-solde"/>
                </VBox>

                <VBox styleClass="card, card-revenu" HBox.hgrow="ALWAYS">
                    <Label text="Revenus" styleClass="card-titre"/>
                    <Region prefHeight="8"/>
                    <Label fx:id="labelRevenus" text="0,00 €"
                           styleClass="card-valeur, valeur-revenu"/>
                </VBox>

                <VBox styleClass="card, card-depense" HBox.hgrow="ALWAYS">
                    <Label text="Depenses" styleClass="card-titre"/>
                    <Region prefHeight="8"/>
                    <Label fx:id="labelDepenses" text="0,00 €"
                           styleClass="card-valeur, valeur-depense"/>
                </VBox>

            </HBox>

            <!-- Graphiques -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <BarChart fx:id="barChart" HBox.hgrow="ALWAYS"
                          styleClass="card" animated="true">
                    <xAxis><CategoryAxis label="Mois"/></xAxis>
                    <yAxis><NumberAxis label="Montant (E)"/></yAxis>
                </BarChart>

                <PieChart fx:id="pieChart" HBox.hgrow="ALWAYS"
                          styleClass="card" animated="true"
                          title="Repartition"/>

            </HBox>

        </VBox>
    </center>

</BorderPane>