<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.TransactionController"
            prefWidth="900" prefHeight="600">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="navbar" prefHeight="60">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="MoneyWise" styleClass="navbar-logo"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Dashboard"
                    styleClass="btn-ghost"
                    onAction="#handleDashboard"
                    style="-fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.4);"/>

            <Button text="Deconnexion"
                    styleClass="btn-danger"
                    onAction="#handleDeconnexion"/>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="20" styleClass="content-area">

            <!-- En-tete -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Mes Transactions" styleClass="page-titre"/>
                    <Label text="Historique complet de vos mouvements financiers"
                           style="-fx-text-fill: #5A7A6A; -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Ajouter une transaction"
                        onAction="#handleAjouter"
                        styleClass="btn-primary"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="tableTransactions" VBox.vgrow="ALWAYS"
                       styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colDate"
                                 text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colDescription"
                                 text="Description" prefWidth="260"/>
                    <TableColumn fx:id="colMontant"
                                 text="Montant" prefWidth="130"/>
                    <TableColumn fx:id="colType"
                                 text="Type" prefWidth="110"/>
                    <TableColumn fx:id="colActions"
                                 text="Actions" prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="Aucune transaction pour le moment."
                           style="-fx-text-fill: #9AB5A8; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

</BorderPane>