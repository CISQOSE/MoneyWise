<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.moneywise.moneywise.controller.LoginController"
           prefWidth="900" prefHeight="600"
           styleClass="login-bg">

    <VBox alignment="CENTER" spacing="0"
          styleClass="login-card"
          maxWidth="420">

        <padding>
            <Insets top="44" right="44" bottom="44" left="44"/>
        </padding>

        <Label text="MoneyWise" styleClass="login-titre"/>
        <Region prefHeight="6"/>
        <Label text="Connectez-vous a votre espace" styleClass="login-sous-titre"/>

        <Region prefHeight="30"/>

        <Label text="Adresse email" styleClass="form-label"/>
        <Region prefHeight="6"/>
        <TextField fx:id="champEmail"
                   promptText="vous@exemple.com"
                   styleClass="champ-saisie"/>

        <Region prefHeight="18"/>

        <Label text="Mot de passe" styleClass="form-label"/>
        <Region prefHeight="6"/>
        <PasswordField fx:id="champMdp"
                       promptText="Votre mot de passe"
                       styleClass="champ-saisie"/>

        <Region prefHeight="26"/>

        <Button fx:id="btnConnexion"
                text="Se connecter"
                maxWidth="Infinity"
                styleClass="btn-primary"
                onAction="#handleConnexion"/>

        <Region prefHeight="16"/>

        <HBox alignment="CENTER">
            <Hyperlink text="Pas encore de compte ? S'inscrire"
                       styleClass="hyperlink"
                       onAction="#handleInscription"/>
        </HBox>

        <Region prefHeight="6"/>

        <Label fx:id="labelMessage" text=""
               styleClass="msg-erreur"
               wrapText="true"/>

    </VBox>

</StackPane>