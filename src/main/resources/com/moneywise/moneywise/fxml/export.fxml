<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.ExportController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #1a1a2e; -fx-padding: 15px;">
            <Label text="💰 MoneyWise"
                   style="-fx-text-fill: white; -fx-font-size: 20px;
                          -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🏠 Dashboard"
                    onAction="#handleDashboard"
                    style="-fx-background-color: #4361ee; -fx-text-fill: white;
                           -fx-background-radius: 6px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="30" alignment="CENTER"
              style="-fx-padding: 50px; -fx-background-color: #f0f2f5;">

            <Label text="📤 Exporter mes données"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

            <Label fx:id="labelInfo" text=""
                   style="-fx-font-size: 14px; -fx-text-fill: #666;"/>

            <!-- Carte PDF -->
            <VBox spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-padding: 30px;
                         -fx-background-radius: 10px; -fx-pref-width: 400px;">
                <Label text="📄 Export PDF"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Génère un rapport PDF de toutes vos transactions"
                       style="-fx-text-fill: #666;"/>
                <Button text="Exporter en PDF"
                        onAction="#handleExportPDF"
                        maxWidth="Infinity"
                        style="-fx-background-color: #e63946; -fx-text-fill: white;
                               -fx-background-radius: 6px; -fx-padding: 12px;
                               -fx-font-size: 14px;"/>
            </VBox>

            <!-- Carte Excel -->
            <VBox spacing="10" alignment="CENTER"
                  style="-fx-background-color: white; -fx-padding: 30px;
                         -fx-background-radius: 10px; -fx-pref-width: 400px;">
                <Label text="📊 Export Excel"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Génère un fichier Excel avec vos données financières"
                       style="-fx-text-fill: #666;"/>
                <Button text="Exporter en Excel"
                        onAction="#handleExportExcel"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2dc653; -fx-text-fill: white;
                               -fx-background-radius: 6px; -fx-padding: 12px;
                               -fx-font-size: 14px;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>