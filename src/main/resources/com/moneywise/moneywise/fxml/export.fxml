<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.ExportController"
            prefWidth="900" prefHeight="600">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="navbar" prefHeight="60">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="MoneyWise" styleClass="navbar-logo"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Dashboard"
                    styleClass="btn-ghost"
                    onAction="#handleDashboard"
                    style="-fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.4);"/>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="24" alignment="TOP_CENTER"
              styleClass="content-area">

            <!-- En-tete -->
            <VBox spacing="4" alignment="CENTER">
                <Label text="Exporter mes donnees" styleClass="page-titre"/>
                <Label fx:id="labelInfo" text=""
                       style="-fx-text-fill: #5A7A6A; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Cartes export -->
            <HBox spacing="20" alignment="CENTER">

                <!-- Carte PDF -->
                <VBox spacing="14" styleClass="export-card">
                    <Label text="Export PDF" styleClass="export-card-titre"/>
                    <Label text="Genere un rapport PDF complet de toutes vos transactions avec totaux et solde."
                           styleClass="export-card-desc"/>
                    <Region prefHeight="4"/>
                    <Button text="Exporter en PDF"
                            onAction="#handleExportPDF"
                            maxWidth="Infinity"
                            styleClass="btn-danger"/>
                </VBox>

                <!-- Carte Excel -->
                <VBox spacing="14" styleClass="export-card">
                    <Label text="Export Excel" styleClass="export-card-titre"/>
                    <Label text="Genere un fichier Excel (.xlsx) avec vos donnees financieres colorisees."
                           styleClass="export-card-desc"/>
                    <Region prefHeight="4"/>
                    <Button text="Exporter en Excel"
                            onAction="#handleExportExcel"
                            maxWidth="Infinity"
                            styleClass="btn-primary"/>
                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>