<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moneywise.moneywise.controller.AdminController"
            prefWidth="900" prefHeight="600">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="navbar" prefHeight="60">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="MoneyWise" styleClass="navbar-logo"/>
            <Label text="- Administration"
                   style="-fx-text-fill: #A8D5BE; -fx-font-size: 16px;"/>
            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Dashboard"
                    styleClass="btn-ghost"
                    onAction="#handleDashboard"
                    style="-fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.4);"/>

            <Button text="Deconnexion"
                    styleClass="btn-danger"
                    onAction="#handleDeconnexion"/>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="20" styleClass="content-area">

            <!-- En-tete -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Gestion des utilisateurs" styleClass="page-titre"/>
                    <Label fx:id="labelStats" text=""
                           style="-fx-text-fill: #5A7A6A; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="tableUtilisateurs" VBox.vgrow="ALWAYS"
                       styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId"
                                 text="ID" prefWidth="55"/>
                    <TableColumn fx:id="colNom"
                                 text="Nom" prefWidth="160"/>
                    <TableColumn fx:id="colEmail"
                                 text="Email" prefWidth="210"/>
                    <TableColumn fx:id="colStatut"
                                 text="Statut" prefWidth="110"/>
                    <TableColumn fx:id="colRole"
                                 text="Role" prefWidth="110"/>
                    <TableColumn fx:id="colActions"
                                 text="Actions" prefWidth="180"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouve."
                           style="-fx-text-fill: #9AB5A8; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

</BorderPane>